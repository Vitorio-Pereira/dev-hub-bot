# Discord
DISCORD_TOKEN=
DISCORD_APP_ID=

# Usado durante desenvolvimento para registrar slash commands só num servidor
# (registro instantâneo, vs. comandos globais que demoram até 1h para propagar).
# Deixe vazio em produção para registrar globalmente.
DISCORD_DEV_GUILD_ID=

# GitHub
# Personal Access Token (fine-grained), só precisa de permissão de leitura
# em repositórios públicos (Contents: Read-only é suficiente).
GITHUB_TOKEN=

# Storage
DATABASE_PATH=./data/dev-hub-bot.db

# Ambiente: development | production
ENV=development